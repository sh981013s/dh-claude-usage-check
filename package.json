{
  "name": "deliveryhero-claude-proxy-monitor",
  "version": "0.1.2",
  "description": "DeliveryHero proxy usage monitor for Claude Code on macOS menu bar",
  "private": false,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "scan:usage": "node scripts/claude-usage-scan.js /tmp/claude-debug.txt",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac dmg zip --publish never",
    "dist:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --publish never",
    "dist:mac:signed": "electron-builder --mac dmg zip --publish never",
    "release:dry": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --publish never"
  },
  "author": "DeliveryHero",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sh981013s/dh-claude-usage-check.git"
  },
  "homepage": "https://github.com/sh981013s/dh-claude-usage-check",
  "bugs": {
    "url": "https://github.com/sh981013s/dh-claude-usage-check/issues"
  },
  "build": {
    "appId": "com.deliveryhero.claudeproxymonitor",
    "productName": "DH Claude Proxy Monitor",
    "files": [
      "src/**/*",
      "scripts/**/*",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "sign": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "sh981013s",
        "repo": "dh-claude-usage-check"
      }
    ]
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  }
}
